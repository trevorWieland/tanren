  "components": {
    "schemas": {
      "Cli": {
        "type": "string",
        "enum": [
          "opencode",
          "codex",
          "claude",
          "bash"
        ],
        "title": "Cli",
        "description": "CLI tool types from PROTOCOL.md Section 2."
      },
      "ConfigResponse": {
        "properties": {
          "ipc_dir": {
            "type": "string",
            "title": "Ipc Dir",
            "description": "IPC directory path"
          },
          "github_dir": {
            "type": "string",
            "title": "Github Dir",
            "description": "Root directory for git repos"
          },
          "poll_interval": {
            "type": "number",
            "title": "Poll Interval",
            "description": "Seconds between polls"
          },
          "heartbeat_interval": {
            "type": "number",
            "title": "Heartbeat Interval",
            "description": "Seconds between heartbeats"
          },
          "max_opencode": {
            "type": "integer",
            "title": "Max Opencode",
            "description": "Max concurrent opencode processes"
          },
          "max_codex": {
            "type": "integer",
            "title": "Max Codex",
            "description": "Max concurrent codex processes"
          },
          "max_gate": {
            "type": "integer",
            "title": "Max Gate",
            "description": "Max concurrent gate processes"
          },
          "events_enabled": {
            "type": "boolean",
            "title": "Events Enabled",
            "description": "Whether event emission is active"
          },
          "remote_enabled": {
            "type": "boolean",
            "title": "Remote Enabled",
            "description": "Whether remote execution is configured"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "ipc_dir",
          "github_dir",
          "poll_interval",
          "heartbeat_interval",
          "max_opencode",
          "max_codex",
          "max_gate",
          "events_enabled",
          "remote_enabled"
        ],
        "title": "ConfigResponse",
        "description": "Non-secret config projection."
      },
      "DispatchAccepted": {
        "properties": {
          "dispatch_id": {
            "type": "string",
            "title": "Dispatch Id",
            "description": "Auto-generated workflow identifier"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Acceptance status",
            "default": "accepted"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "dispatch_id"
        ],
        "title": "DispatchAccepted",
        "description": "Thin response confirming dispatch acceptance."
      },
      "DispatchRequest": {
        "properties": {
          "project": {
            "type": "string",
            "title": "Project",
            "description": "Project name matching repo name"
          },
          "phase": {
            "$ref": "#/components/schemas/Phase",
            "description": "Dispatch phase type"
          },
          "branch": {
            "type": "string",
            "title": "Branch",
            "description": "Git branch name"
          },
          "spec_folder": {
            "type": "string",
            "title": "Spec Folder",
            "description": "Relative path to spec folder"
          },
          "cli": {
            "$ref": "#/components/schemas/Cli",
            "description": "CLI tool to use"
          },
          "model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model",
            "description": "Model identifier"
          },
          "timeout": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Timeout",
            "description": "Max execution time in seconds",
            "default": 1800
          },
          "environment_profile": {
            "type": "string",
            "title": "Environment Profile",
            "description": "Environment profile name",
            "default": "default"
          },
          "context": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Context",
            "description": "Extra context for the agent"
          },
          "gate_cmd": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
