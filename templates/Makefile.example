# tanren Makefile example
# Copy this to your project root as `Makefile` and customize.

.PHONY: check ci all

# Fast local checks (lint, type-check, unit tests)
check:
	@echo "Running checks..."
	# Add your lint/type/test commands here
	# Example for Python+uv:
	# uv run ruff check .
	# uv run mypy src/
	# uv run pytest tests/unit/ -x -q

# CI checks (everything in check + integration tests)
ci: check
	@echo "Running CI checks..."
	# Add integration/slower tests here
	# uv run pytest tests/integration/ -x -q

# Full build + all checks
all: ci
	@echo "All checks passed."
