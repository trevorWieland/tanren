### 2.5 ProgressJsonDocument (progress.json)

```json
{
  "schema_version": "v1",
  "contract_version": "v1",
  "spec_id": "<uuid-v7>",
  "generated_at": "<iso-8601>",
  "task_counts": {
    "pending": 0,
    "in_progress": 0,
    "implemented": 0,
    "complete": 0,
    "abandoned": 0,
    "total": 0
  },
  "first_event_at": "<iso-8601|null>",
  "last_event_at": "<iso-8601|null>",
  "latest_event_id": "<uuid-v7|null>",
  "latest_phase": "<string|null>"
}
```

### 2.6 DemoFrontmatter (demo.md)

```yaml
---
schema_version: v1
kind: demo
spec_id: <uuid-v7>
environment:
  probed_at: <iso-8601>
  connections_verified: <bool>
steps:
  - id: <string>
    mode: <RUN|SKIP>
    description: <string>
    expected_observable: <string>
    skip_reason: <string, present iff mode=SKIP>
results:                     # append-only per RUN_DEMO session
  - run_id: <uuid-v7>
    ran_at: <iso-8601>
    step_id: <string>
    status: <pass|fail>
    observed: <string>
---
<narrative walkthrough>
```

### 2.7 AuditFrontmatter (audit.md)

```yaml
---
kind: audit
spec_id: <uuid-v7>
scope: <task|spec>
scope_target_id: <string, present when scope=task>
status: <pass|fail>
fix_now_count: <u32>
rubric:
  - pillar: <string>
    score: <u8, 1..=10>
    rationale: <string>
    supporting_finding_ids: [<uuid-v7>]
non_negotiables_compliance:
  - name: <string>
    status: <pass|fail>
    rationale: <string>
findings: [<uuid-v7>]     # references in Finding projection
generated_at: <iso-8601>
---
<narrative reasoning>
```

### 2.8 SignpostsFrontmatter (signposts.md)

```yaml
---
kind: signposts
spec_id: <uuid-v7>
entries:
  - id: <uuid-v7>
    task_id: <uuid-v7 | null>
    status: <unresolved|resolved|deferred|architectural_constraint>
    problem: <string>
    evidence: <string>
    tried: [<string>]
    solution: <string | null>
    resolution: <string | null>
    files_affected: [<string>]
    created_at: <iso-8601>
    updated_at: <iso-8601>
---
<optional narrative>
```

### 2.9 InvestigationReport (investigation-report.json)

```json
{
  "kind": "investigation",
  "spec_id": "<uuid-v7>",
  "investigation_id": "<uuid-v7>",
  "trigger": {
    "phase": "do-task|task-gate|audit-task|adhere-task|run-demo|spec-gate|audit-spec|adhere-spec",
    "task_id": "<uuid-v7 | null>",
    "error_fingerprint": "<string>",
    "loop_index": <u16>
  },
  "root_causes": [
    {
      "description": "<string>",
      "confidence": "high|medium|low",
      "affected_files": ["<string>"],
      "category": "code_bug|spec_ambiguity|acceptance_criteria_gap|environment_drift|test_gap|external_dependency",
      "suggested_actions": [
        { "kind": "revise_task",  "task_id": "<uuid-v7>", "reason": "<string>" },
        { "kind": "create_task",  "title": "<string>", "description": "<string>", "origin_detail": "<string>" },
        { "kind": "escalate",     "reason": "<string>" }
      ]
    }
  ],
  "narrative": "<string, free prose>",
  "generated_at": "<iso-8601>"
}
```

