+    world.operational_snapshot = vec![
+        "tasks:consistent".to_string(),
+        "findings:consistent".to_string(),
+        "progress:inconsistent".to_string(),
+    ];
+    world.projection_snapshot = vec![
+        "tasks:consistent".to_string(),
