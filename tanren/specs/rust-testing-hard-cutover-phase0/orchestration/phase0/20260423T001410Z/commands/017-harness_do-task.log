 ---
 
+## Staged Gate Scaffolding (Current Non-Blocking Contract)
+
+While the Rust testing cutover is in progress, staged gate scaffolds are
+available in `justfile` and exercised by CI:
+
+```bash
+just check-phase0-scenario-stage
+just check-phase0-bdd-smoke
+just check-phase0-mutation-stage
+just check-phase0-coverage-stage
+just check-phase0-stage-gates
+```
+
+Current behavior:
+
+- commands are non-blocking scaffolds that emit readiness/status signals,
+- `check-phase0-bdd-smoke` executes a cucumber-rs smoke scenario and emits the
+  feature tag line as traceability evidence,
+- they are intended for per-task demonstrability while implementation lands,
+- strict blocking enforcement remains a later cutover task.
+
+---
+
 ## Artifact Layout
 
 ```text
diff --git a/justfile b/justfile
index 45e9368..867b364 100644
--- a/justfile
+++ b/justfile
@@ -288,6 +288,87 @@ doc:
 # Quality Gates
 # ============================================================================
 
+# Phase 0 staged scenario gate scaffold (non-blocking until final enforcement).
+check-phase0-scenario-stage:
+    #!/usr/bin/env bash
+    set -euo pipefail
+
+    bdd_source="docs/rewrite/PHASE0_PROOF_BDD.md"
+    scenario_count=0
+    if [[ -f "$bdd_source" ]]; then
+        scenario_count="$(grep -Ec '^### Scenario [0-9]+\.[0-9]+:' "$bdd_source" || true)"
+        echo "Phase 0 scenario scaffold: found ${scenario_count} scenario headings in ${bdd_source}."
+    else
+        echo "Phase 0 scenario scaffold: ${bdd_source} not found (non-blocking in scaffold mode)."
+    fi
+
+    feature_count=0
+    if [[ -d tests/bdd/phase0 ]]; then
+        feature_count="$(find tests/bdd/phase0 -type f -name '*.feature' | wc -l | tr -d '[:space:]')"
+    fi
+    echo "Phase 0 scenario scaffold: detected ${feature_count} feature file(s) under tests/bdd/phase0."
+
+# Run a cucumber-rs smoke scenario for the Phase 0 BDD harness scaffold.
+check-phase0-bdd-smoke:
+    #!/usr/bin/env bash
+    set -euo pipefail
+
+    feature_file="tests/bdd/phase0/smoke.feature"
+    if [[ ! -f "$feature_file" ]]; then
+        echo "FAIL: missing Phase 0 smoke feature at ${feature_file}."
+        exit 1
+    fi
+
+    {{ cargo }} run --quiet -p tanren-bdd-phase0 --locked
+
+    tag_line="$(grep -E '^@' "$feature_file" | head -n 1 || true)"
+    if [[ -z "$tag_line" ]]; then
+        echo "FAIL: no tag line found in ${feature_file}."
+        exit 1
+    fi
+    echo "Phase 0 BDD smoke tag evidence: ${tag_line}"
+
+# Phase 0 staged mutation gate scaffold (non-blocking until final enforcement).
+check-phase0-mutation-stage:
+    #!/usr/bin/env bash
+    set -euo pipefail
+
+    if command -v cargo-mutants >/dev/null 2>&1; then
+        mutants_version="$(cargo-mutants --version 2>/dev/null || true)"
+        if [[ -n "$mutants_version" ]]; then
+            echo "Phase 0 mutation scaffold: ${mutants_version}"
+        else
+            echo "Phase 0 mutation scaffold: cargo-mutants is installed."
+        fi
+    else
+        echo "Phase 0 mutation scaffold: cargo-mutants not installed yet (non-blocking in scaffold mode)."
+    fi
+
+    if [[ -f mutants.toml ]]; then
+        echo "Phase 0 mutation scaffold: found mutants.toml."
+    else
+        echo "Phase 0 mutation scaffold: mutants.toml not present yet (expected before final enforcement)."
+    fi
+
+# Phase 0 staged coverage gate scaffold (non-blocking until final enforcement).
+check-phase0-coverage-stage:
+    #!/usr/bin/env bash
+    set -euo pipefail
+
+    if coverage_version="$({{ cargo }} llvm-cov --version 2>/dev/null)"; then
+        echo "Phase 0 coverage scaffold: ${coverage_version}"
+    else
+        echo "Phase 0 coverage scaffold: cargo llvm-cov unavailable yet (non-blocking in scaffold mode)."
+    fi
+    echo "Phase 0 coverage scaffold: behavior-gap classification enforcement is staged for a later task."
+
+# Run all staged Phase 0 behavior gate scaffolds.
+check-phase0-stage-gates:
+    @just check-phase0-scenario-stage
+    @just check-phase0-bdd-smoke
+    @just check-phase0-mutation-stage
+    @just check-phase0-coverage-stage
+
 # Enforce max file line count (500 lines per .rs file)
 check-lines:
     #!/usr/bin/env bash
@@ -543,6 +624,8 @@ ci:
     @just check-deps
     @echo "==> CI parity guard"
     @just check-ci-parity
+    @echo "==> Phase 0 staged behavior gates (non-blocking scaffold)"
+    @just check-phase0-stage-gates
     @echo "==> Dependency audit"
     @just deny
     @echo "==> Docs"

