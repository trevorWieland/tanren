+    );
+}
+
+#[then("no unintended mutation occurs")]
+fn then_no_unintended_mutation_occurs(world: &mut Phase0World) {
+    assert_eq!(world.protected_mutation_count, 0);
+    assert_eq!(world.lifecycle_state, LifecycleState::New);
+}
