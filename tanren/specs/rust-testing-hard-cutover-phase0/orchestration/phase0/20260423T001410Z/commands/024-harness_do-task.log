+    world.persisted_revision = 0;
+    world.persisted_revision_before_attempt = 0;
+}
+
+#[when("a valid sequence of lifecycle mutations is submitted")]
+fn when_valid_lifecycle_sequence_submitted(world: &mut Phase0World) {
