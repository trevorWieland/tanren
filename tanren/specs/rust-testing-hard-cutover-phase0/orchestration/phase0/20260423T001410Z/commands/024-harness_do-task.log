+    ReplayCredential,
+}
+
+#[derive(Debug, cucumber::World)]
+struct Phase0World {
+    smoke_initialized: bool,
+    smoke_executed: bool,
+
+    lifecycle_state: LifecycleState,
+    lifecycle_trace: Vec<LifecycleState>,
+    query_surface_status: LifecycleState,
