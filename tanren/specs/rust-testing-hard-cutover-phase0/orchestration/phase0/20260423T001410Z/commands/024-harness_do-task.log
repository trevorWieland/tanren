use cucumber::{World as _, given, then, when};

#[derive(Debug, Default, cucumber::World)]
struct SmokeWorld {
    initialized: bool,
    executed: bool,
}

#[given("the phase0 BDD harness is initialized")]
fn given_harness_initialized(world: &mut SmokeWorld) {
    world.initialized = true;
}

#[when("the smoke scenario executes")]
fn when_smoke_scenario_executes(world: &mut SmokeWorld) {
    world.executed = true;
}

#[then("the scenario completes successfully")]
fn then_scenario_completes_successfully(world: &mut SmokeWorld) {
    assert!(world.initialized && world.executed);
}

#[tokio::main(flavor = "current_thread")]
async fn main() {
    SmokeWorld::cucumber()
        .max_concurrent_scenarios(1)
        .fail_on_skipped()
        .run_and_exit("tests/bdd/phase0/smoke.feature")
        .await;
}

