    95	        relpath = normalize_path(filename, repo_root)
    96	        by_file[relpath] = {
    97	            "path": relpath,
    98	            "lines": {
    99	                "count": int(lines.get("count", 0)),
   100	                "covered": int(lines.get("covered", 0)),
   101	                "percent": float(lines.get("percent", 0.0)),
   102	            },
