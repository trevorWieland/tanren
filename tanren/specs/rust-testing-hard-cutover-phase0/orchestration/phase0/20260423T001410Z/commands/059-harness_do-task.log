   118	def load_feature_executions(path: Path) -> dict[str, dict[str, Any]]:
   119	    """Load NDJSON feature execution rows keyed by feature path."""
   120	    rows: dict[str, dict[str, Any]] = {}
   121	    if not path.exists():
   122	        return rows
   123	
   124	    for line in path.read_text(encoding="utf-8").splitlines():
   125	        if not line.strip():
   126	            continue
   127	        try:
   128	            row = json.loads(line)
   129	        except json.JSONDecodeError:
   130	            continue
   131	        if not isinstance(row, dict):
   132	            continue
   133	        feature_file = row.get("feature_file")
   134	        if not isinstance(feature_file, str) or not feature_file:
   135	            continue
   136	        rows[feature_file] = {
   137	            "status": row.get("status", "unknown"),
   138	            "exit_code": int(row.get("exit_code", 0)),
   139	        }
   140	    return rows
