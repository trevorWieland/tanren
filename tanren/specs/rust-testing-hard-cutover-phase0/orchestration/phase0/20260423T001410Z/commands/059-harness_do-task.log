   102	def missing_snippets(content: str, snippets: list[str]) -> list[str]:
   103	    """Return snippets that are absent from `content`."""
   104	    return [snippet for snippet in snippets if snippet not in content]
   105	
   106	
   107	def main() -> int:
   108	    """Validate parity-critical command snippets in CI, justfile, and wrapper.
   109	
   110	    Returns:
   111	        Exit status code (0 on success, 1 when required snippets are missing).
   112	    """
   113	    workflow = WORKFLOW_PATH.read_text(encoding="utf-8")
   114	    justfile = JUSTFILE_PATH.read_text(encoding="utf-8")
   115	    wrapper = WRAPPER_PATH.read_text(encoding="utf-8")
   116	
   117	    missing_workflow = missing_snippets(workflow, WORKFLOW_REQUIRED)
   118	    missing_just = missing_snippets(justfile, JUST_REQUIRED)
   119	    missing_wrapper = missing_snippets(wrapper, WRAPPER_REQUIRED)
   120	
   121	    if missing_workflow or missing_just or missing_wrapper:
   122	        print("ERROR: CI parity drift detected.")
   123	        if missing_workflow:
   124	            print("\nMissing from workflow:")
   125	            for snippet in missing_workflow:
   126	                print(f"  - {snippet}")
   127	        if missing_just:
   128	            print("\nMissing from justfile:")
   129	            for snippet in missing_just:
   130	                print(f"  - {snippet}")
   131	        if missing_wrapper:
   132	            print("\nMissing from scripts/run_postgres_integration.sh:")
   133	            for snippet in missing_wrapper:
   134	                print(f"  - {snippet}")
   135	        return 1
   136	
   137	    print("CI parity check passed.")
   138	    return 0
   139	
   140	
   141	if __name__ == "__main__":
   142	    raise SystemExit(main())

