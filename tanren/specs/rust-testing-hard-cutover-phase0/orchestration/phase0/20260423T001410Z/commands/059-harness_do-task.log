   183	def classify_behavior_coverage(
   184	    inventory: list[dict[str, str]],
   185	    feature_executions: dict[str, dict[str, Any]],
   186	    coverage_by_file: dict[str, dict[str, Any]],
   187	) -> tuple[list[dict[str, Any]], list[dict[str, Any]]]:
   188	    """Classify behaviors as covered or missing using feature + source evidence."""
   189	    covered: list[dict[str, Any]] = []
   190	    missing: list[dict[str, Any]] = []
   191	
   192	    for row in inventory:
   193	        behavior_id = row["behavior_id"]
   194	        wave = row["wave"]
   195	        feature_path = row["planned_feature_file"]
   196	        source_path = WAVE_SOURCE_MAP.get(wave)
   197	        feature_exec = feature_executions.get(feature_path, {"status": "not_executed", "exit_code": 0})
   198	        source_cov = coverage_by_file.get(source_path, {}) if source_path else {}
   199	
   200	        feature_status = str(feature_exec.get("status", "not_executed"))
   201	        feature_exit_code = int(feature_exec.get("exit_code", 0))
   202	        source_lines = source_cov.get("lines", {}) if isinstance(source_cov, dict) else {}
   203	        source_lines_covered = int(source_lines.get("covered", 0)) if isinstance(source_lines, dict) else 0
   204	        source_line_percent = (
   205	            float(source_lines.get("percent", 0.0)) if isinstance(source_lines, dict) else 0.0
   206	        )
   207	
   208	        entry = {
   209	            "behavior_id": behavior_id,
   210	            "scenario_id": row["scenario_id"],
   211	            "wave": wave,
   212	            "planned_feature_file": feature_path,
   213	            "feature_status": feature_status,
   214	            "feature_exit_code": feature_exit_code,
   215	            "source_path": source_path,
   216	            "source_line_percent": source_line_percent,
   217	        }
   218	
   219	        if feature_status != "passed":
   220	            entry["classification"] = "missing_behavior"
   221	            entry["reason"] = "planned_feature_not_passing"
   222	            missing.append(entry)
   223	            continue
   224	
   225	        if not source_path:
   226	            entry["classification"] = "missing_behavior"
   227	            entry["reason"] = "wave_has_no_source_mapping"
   228	            missing.append(entry)
   229	            continue
   230	
   231	        if not source_cov:
   232	            entry["classification"] = "missing_behavior"
   233	            entry["reason"] = "source_missing_from_coverage_report"
   234	            missing.append(entry)
   235	            continue
   236	
   237	        if source_lines_covered == 0:
   238	            entry["classification"] = "missing_behavior"
   239	            entry["reason"] = "source_has_zero_covered_lines"
   240	            missing.append(entry)
   241	            continue
   242	
   243	        entry["classification"] = "covered_behavior"
   244	        entry["reason"] = "planned_feature_passed_and_wave_source_covered"
   245	        covered.append(entry)
   246	
   247	    return covered, missing
