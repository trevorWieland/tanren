   456	# Enforce crate dependency layering (foundation crates must not depend on capability crates)
   457	check-deps:
   458	    #!/usr/bin/env bash
   459	    set -euo pipefail
   460	    echo "Checking crate dependency layering..."
   461	
   462	    # Foundation crates: domain logic, no I/O, no orchestration
   463	    foundation=(
   464	        "tanren-domain"
   465	        "tanren-contract"
   466	        "tanren-policy"
   467	        "tanren-observability"
   468	    )
   469	
   470	    # Capability crates: these must NOT be depended upon by foundation crates
   471	    capability=(
   472	        "tanren-store"
   473	        "tanren-planner"
   474	        "tanren-scheduler"
   475	        "tanren-orchestrator"
   476	        "tanren-app-services"
   477	        "tanren-runtime"
   478	        "tanren-runtime-local"
   479	        "tanren-runtime-docker"
   480	        "tanren-runtime-remote"
   481	        "tanren-harness-claude"
   482	        "tanren-harness-codex"
   483	        "tanren-harness-opencode"
   484	    )
   485	
   486	    failed=0
   487	    metadata=$({{ cargo }} metadata --format-version 1 --no-deps 2>/dev/null)
   488	
   489	    # Normal (non-dev, non-build) dependencies only. `cargo metadata`
   490	    # tags dev-dependencies with `kind="dev"` — those are test-only
   491	    # and never land in the shipped binary, so they do not constitute
   492	    # a layering violation.
   493	    for fnd in "${foundation[@]}"; do
   494	        deps=$(echo "$metadata" \
   495	            | jq -r ".packages[] | select(.name == \"$fnd\") | .dependencies[] | select(.kind == null) | .name" 2>/dev/null || true)
   496	        for cap in "${capability[@]}"; do
   497	            if echo "$deps" | grep -qx "$cap"; then
   498	                echo "FAIL: foundation crate '$fnd' depends on capability crate '$cap'"
   499	                failed=1
   500	            fi
   501	        done
   502	    done
   503	
   504	    # Transport binaries must stay thin: no direct core/capability deps.
   505	    transport=(
   506	        "tanren-cli"
   507	        "tanren-api"
   508	        "tanren-mcp"
   509	        "tanren-tui"
   510	    )
   511	    forbidden_transport=(
   512	        "tanren-domain"
   513	        "tanren-policy"
   514	        "tanren-store"
   515	        "tanren-planner"
   516	        "tanren-scheduler"
   517	        "tanren-orchestrator"
   518	    )
   519	    for bin in "${transport[@]}"; do
   520	        deps=$(echo "$metadata" \
   521	            | jq -r ".packages[] | select(.name == \"$bin\") | .dependencies[] | select(.kind == null) | .name" 2>/dev/null || true)
   522	        for forbidden in "${forbidden_transport[@]}"; do
   523	            if echo "$deps" | grep -qx "$forbidden"; then
   524	                echo "FAIL: transport binary '$bin' depends directly on '$forbidden'"
   525	                failed=1
   526	            fi
   527	        done
   528	    done
   529	
   530	    # Store row-shape entities must remain crate-internal.
   531	    if grep -Eq '^[[:space:]]*pub mod entity;' crates/tanren-store/src/lib.rs; then
   532	        echo "FAIL: crates/tanren-store/src/lib.rs exports 'pub mod entity;'"
   533	        failed=1
   534	    fi
   535	    if grep -Eq '^[[:space:]]*pub mod (dispatch_projection|events|step_projection);' crates/tanren-store/src/entity/mod.rs; then
   536	        echo "FAIL: crates/tanren-store/src/entity/mod.rs exposes row-shape modules publicly"
   537	        failed=1
   538	    fi
   539	    if ! awk '
   540	        prev_cfg && /^[[:space:]]*pub use state_store::dispatch_query_statement_for_backend;/ {ok=1}
   541	        { prev_cfg = ($0 ~ /^[[:space:]]*#\[cfg\(feature = "test-hooks"\)\][[:space:]]*$/) }
   542	        END { exit ok ? 0 : 1 }
   543	    ' crates/tanren-store/src/lib.rs; then
   544	        echo "FAIL: dispatch_query_statement_for_backend re-export must be gated by #[cfg(feature = \"test-hooks\")]"
   545	        failed=1
   546	    fi
   547	    if ! awk '
   548	        prev_cfg && /^[[:space:]]*pub fn dispatch_query_statement_for_backend\(/ {ok=1}
   549	        { prev_cfg = ($0 ~ /^[[:space:]]*#\[cfg\(feature = "test-hooks"\)\][[:space:]]*$/) }
   550	        END { exit ok ? 0 : 1 }
   551	    ' crates/tanren-store/src/state_store.rs; then
   552	        echo "FAIL: dispatch_query_statement_for_backend function must be gated by #[cfg(feature = \"test-hooks\")]"
   553	        failed=1
   554	    fi
   555	
   556	    if [[ "$failed" -eq 1 ]]; then
   557	        echo "Dependency/boundary rule violations detected."
   558	        exit 1
   559	    fi
   560	    echo "Crate layering rules pass."
