   562	# Verify local CI recipes stay aligned with workflow strict rust commands.
   563	check-ci-parity:
   564	    #!/usr/bin/env bash
   565	    set -euo pipefail
   566	
   567	    uv_bin="$(command -v uv || true)"
   568	    if [[ -z "$uv_bin" && -x "$HOME/.local/bin/uv" ]]; then
   569	        uv_bin="$HOME/.local/bin/uv"
   570	    fi
   571	    if [[ -z "$uv_bin" ]]; then
   572	        echo "FAIL: uv not found. Install uv or add it to PATH."
   573	        exit 127
   574	    fi
   575	
   576	    # Keep cache local when HOME cache is unavailable (sandboxed runs).
   577	    export UV_CACHE_DIR="${UV_CACHE_DIR:-$PWD/.uv-cache}"
   578	    "$uv_bin" run python scripts/check_ci_parity.py
   579	
   580	# Verify active rustc/clippy match the pinned toolchain in rust-toolchain.toml.
   581	check-rust-toolchain-sync:
   582	    #!/usr/bin/env bash
   583	    set -euo pipefail
   584	
   585	    expected="$(awk -F'"' '/^channel[[:space:]]*=/{print $2; exit}' rust-toolchain.toml)"
   586	    if [[ -z "${expected:-}" ]]; then
   587	        echo "FAIL: rust-toolchain.toml missing pinned channel."
   588	        exit 1
   589	    fi
   590	
   591	    rustc_version="$(rustc -V | awk '{print $2}')"
   592	    if [[ "$rustc_version" != "$expected" ]]; then
   593	        echo "FAIL: active rustc is ${rustc_version}, expected ${expected} from rust-toolchain.toml."
   594	        exit 1
   595	    fi
   596	
   597	    rustc_hash="$(rustc -Vv | awk '$1 == "commit-hash:" {print $2}')"
   598	    clippy_hash="$(
   599	        cargo clippy --version \
   600	            | awk -F'[()]' '{print $2}' \
   601	            | awk '{print $1}' \
   602	            | awk '/^[0-9a-f]+$/ {print; exit}'
   603	    )"
   604	    if [[ -z "${rustc_hash:-}" || -z "${clippy_hash:-}" ]]; then
   605	        echo "FAIL: unable to parse rustc/clippy version metadata."
   606	        exit 1
   607	    fi
   608	
   609	    rustc_short="${rustc_hash:0:10}"
   610	    if [[ "$clippy_hash" != "$rustc_short" ]]; then
   611	        echo "FAIL: clippy commit ${clippy_hash} does not match rustc commit ${rustc_short}."
   612	        exit 1
   613	    fi
   614	    echo "Rust toolchain sync check passed (${expected}, ${rustc_short})."
   615	
   616	# Prohibit inline lint suppression (#[allow/expect])
   617	check-suppression:
   618	    #!/usr/bin/env bash
   619	    set -euo pipefail
   620	    echo "Checking for inline lint suppression..."
   621	    found=0
   622	    if grep -rn '#\[allow(' crates/ bin/ --include='*.rs' 2>/dev/null; then
   623	        echo "FAIL: Found #[allow(...)] in source. Move to [lints] in Cargo.toml."
   624	        found=1
   625	    fi
   626	    if grep -rn '#\[expect(' crates/ bin/ --include='*.rs' 2>/dev/null; then
   627	        echo "FAIL: Found #[expect(...)] in source. Move to [lints] in Cargo.toml."
   628	        found=1
   629	    fi
   630	    if grep -rn '#!\[allow(' crates/ bin/ --include='*.rs' 2>/dev/null; then
   631	        echo "FAIL: Found #![allow(...)] in source. Move to [lints] in Cargo.toml."
   632	        found=1
   633	    fi
   634	    if [[ "$found" -eq 1 ]]; then exit 1; fi
   635	    echo "No inline lint suppression found."
