diff --git a/.github/workflows/rust-ci.yml b/.github/workflows/rust-ci.yml
index 262a7ec97a43cf93e3a27645db92ec69e1cf0027..350e4608ea787fbaf286ddde78d8d1cbeee43454
--- a/.github/workflows/rust-ci.yml
+++ b/.github/workflows/rust-ci.yml
@@ -261,6 +261,14 @@
           path: artifacts/phase0-mutation/staged/latest
           if-no-files-found: warn
 
+      - name: Upload Phase 0 staged coverage classification artifact
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: phase0-coverage-stage
+          path: artifacts/phase0-coverage/staged/latest
+          if-no-files-found: warn
