+# Phase 0 staged scenario gate scaffold (non-blocking until final enforcement).
+check-phase0-scenario-stage:
+    #!/usr/bin/env bash
+    set -euo pipefail
+
+    bdd_source="docs/rewrite/PHASE0_PROOF_BDD.md"
+    scenario_count=0
