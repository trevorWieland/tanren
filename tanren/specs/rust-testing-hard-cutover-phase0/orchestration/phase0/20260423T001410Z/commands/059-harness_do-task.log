   143	def load_behavior_inventory(traceability_path: Path) -> list[dict[str, str]]:
   144	    """Extract normalized behavior inventory rows from the traceability artifact."""
   145	    payload = load_json(traceability_path)
   146	    inventory = payload.get("behavior_inventory")
   147	    if not isinstance(inventory, list):
   148	        return []
   149	
   150	    rows: list[dict[str, str]] = []
   151	    for row in inventory:
   152	        if not isinstance(row, dict):
   153	            continue
   154	        behavior_id = row.get("behavior_id")
   155	        scenario_id = row.get("scenario_id")
   156	        wave = row.get("wave")
   157	        obligations = row.get("obligations")
   158	        if not isinstance(behavior_id, str) or not behavior_id:
   159	            continue
   160	        if not isinstance(scenario_id, str):
   161	            scenario_id = ""
   162	        if not isinstance(wave, str):
   163	            wave = ""
   164	        planned_feature_file = ""
   165	        if isinstance(obligations, dict):
   166	            positive = obligations.get("positive")
   167	            if isinstance(positive, dict):
   168	                candidate = positive.get("planned_feature_file")
   169	                if isinstance(candidate, str):
   170	                    planned_feature_file = candidate
   171	
   172	        rows.append(
   173	            {
   174	                "behavior_id": behavior_id,
   175	                "scenario_id": scenario_id,
   176	                "wave": wave,
   177	                "planned_feature_file": planned_feature_file,
   178	            }
   179	        )
   180	    return rows
