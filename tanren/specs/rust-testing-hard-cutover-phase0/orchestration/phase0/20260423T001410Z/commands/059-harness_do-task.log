   130	
   131	fn transition_allowed(from: LifecycleState, to: LifecycleState) -> bool {
   132	    matches!(
   133	        (from, to),
   134	        (LifecycleState::New, LifecycleState::Planned)
   135	            | (LifecycleState::Planned, LifecycleState::Active)
   136	            | (LifecycleState::Active, LifecycleState::Completed)
   137	            | (LifecycleState::Active, LifecycleState::Cancelled)
   138	    )
   139	}
   140	
   141	fn submit_lifecycle_transition(
   142	    world: &mut Phase0World,
   143	    next: LifecycleState,
   144	) -> Result<(), MutationErrorCode> {
   145	    if !transition_allowed(world.lifecycle_state, next) {
   146	        world.last_mutation_error = Some(MutationErrorCode::InvalidTransition);
   147	        return Err(MutationErrorCode::InvalidTransition);
   148	    }
   149	
   150	    world.lifecycle_state = next;
   151	    world.lifecycle_trace.push(next);
   152	    world.query_surface_status = next;
   153	    world.persisted_revision += 1;
   154	    world.last_mutation_error = None;
   155	    Ok(())
   156	}
   157	
   158	fn parse_replay_event(event: &str) -> Option<String> {
   159	    let status = event.strip_prefix("status:")?;
   160	    if matches!(status, "planned" | "active" | "completed" | "cancelled") {
   161	        return Some(event.to_string());
   162	    }
   163	    None
   164	}
   165	
   166	fn replay_history(world: &mut Phase0World) {
   167	    let mut scratch = Vec::new();
   168	
   169	    for (index, event) in world.replay_source_history.iter().enumerate() {
   170	        let Some(parsed_event) = parse_replay_event(event) else {
   171	            world.replay_error = Some(format!("invalid_event_at_index:{index}"));
   172	            world.replayed_snapshot.clear();
   173	            world.replay_applied_count = 0;
   174	            return;
   175	        };
   176	        scratch.push(parsed_event);
   177	    }
   178	
   179	    world.replay_error = None;
   180	    world.replayed_snapshot = scratch;
   181	    world.replay_applied_count = world.replayed_snapshot.len();
   182	}
   183	
   184	fn auth_error_label(error: AuthErrorCode) -> &'static str {
   185	    match error {
   186	        AuthErrorCode::InvalidIdentity => "invalid_identity",
   187	        AuthErrorCode::ReplayCredential => "replay_credential",
   188	    }
   189	}
   190	
   191	fn authorize(world: &Phase0World, replay_credential_used: bool) -> Result<(), AuthErrorCode> {
   192	    if !world.actor_identity_valid {
   193	        return Err(AuthErrorCode::InvalidIdentity);
   194	    }
   195	    if replay_credential_used || !world.replay_credential_fresh {
   196	        return Err(AuthErrorCode::ReplayCredential);
   197	    }
   198	    Ok(())
   199	}
   200	
   201	fn execute_protected_command(
   202	    world: &mut Phase0World,
   203	    command: &str,
   204	    replay_credential_used: bool,
   205	) -> Result<(), AuthErrorCode> {
   206	    authorize(world, replay_credential_used)?;
   207	
   208	    match command {
   209	        "create" => {
   210	            if world.lifecycle_state == LifecycleState::New {
   211	                world.lifecycle_state = LifecycleState::Active;
   212	                world.protected_mutation_count += 1;
   213	                world.command_outcomes.push("create:accepted".to_string());
   214	            } else {
   215	                world
   216	                    .command_outcomes
   217	                    .push("create:rejected:invalid_transition".to_string());
   218	            }
   219	        }
   220	        "inspect" => world.command_outcomes.push("inspect:accepted".to_string()),
   221	        "list" => world.command_outcomes.push("list:accepted".to_string()),
   222	        "cancel" => {
   223	            if world.lifecycle_state == LifecycleState::Active {
   224	                world.lifecycle_state = LifecycleState::Cancelled;
   225	                world.protected_mutation_count += 1;
   226	                world.command_outcomes.push("cancel:accepted".to_string());
   227	            } else {
   228	                world
   229	                    .command_outcomes
   230	                    .push("cancel:rejected:invalid_transition".to_string());
   231	            }
   232	        }
   233	        _ => world
   234	            .command_outcomes
   235	            .push("unknown:rejected:unsupported_command".to_string()),
   236	    }
   237	
   238	    Ok(())
   239	}
