   440	# Enforce max file line count (500 lines per .rs file)
   441	check-lines:
   442	    #!/usr/bin/env bash
   443	    set -euo pipefail
   444	    echo "Checking .rs files for line count > {{ max_lines }}..."
   445	    failed=0
   446	    while IFS= read -r -d '' file; do
   447	        lines=$(wc -l < "$file")
   448	        if [[ "$lines" -gt {{ max_lines }} ]]; then
   449	            echo "FAIL: $file has $lines lines (max {{ max_lines }})"
   450	            failed=1
   451	        fi
   452	    done < <(find crates/ bin/ -name '*.rs' -print0)
   453	    if [[ "$failed" -eq 1 ]]; then exit 1; fi
   454	    echo "All files within line limit."
