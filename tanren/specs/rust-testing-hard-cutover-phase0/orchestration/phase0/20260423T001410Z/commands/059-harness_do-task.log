   250	def classify_non_behavior_code(
   251	    coverage_by_file: dict[str, dict[str, Any]],
   252	) -> list[dict[str, Any]]:
   253	    """Classify covered files that are not behavior-owner source files."""
   254	    behavior_sources = set(WAVE_SOURCE_MAP.values())
   255	    rows: list[dict[str, Any]] = []
   256	
   257	    for path, summary in sorted(coverage_by_file.items()):
   258	        if path in behavior_sources:
   259	            continue
   260	        lines = summary.get("lines", {})
   261	        lines_covered = int(lines.get("covered", 0)) if isinstance(lines, dict) else 0
   262	        line_percent = float(lines.get("percent", 0.0)) if isinstance(lines, dict) else 0.0
   263	
   264	        if lines_covered == 0:
   265	            bucket = "dead_or_unexercised_support_code"
   266	            rationale = "file is unmapped to BEH inventory and has zero covered lines"
   267	        else:
   268	            bucket = "support_code"
   269	            rationale = "file is unmapped to BEH inventory but exercised during coverage run"
   270	
   271	        rows.append(
   272	            {
   273	                "path": path,
   274	                "classification": bucket,
   275	                "line_percent": line_percent,
   276	                "rationale": rationale,
   277	            }
   278	        )
   279	    return rows
