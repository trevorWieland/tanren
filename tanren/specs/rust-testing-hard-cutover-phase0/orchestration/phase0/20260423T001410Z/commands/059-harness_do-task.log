    56	def load_coverage_summary(summary_path: Path, repo_root: Path) -> tuple[dict[str, dict[str, Any]], dict[str, Any]]:
    57	    """Load per-file and total summary metrics from llvm-cov JSON."""
    58	    payload = load_json(summary_path)
