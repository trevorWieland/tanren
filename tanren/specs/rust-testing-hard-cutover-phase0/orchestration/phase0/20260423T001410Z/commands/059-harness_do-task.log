    80	        if not isinstance(filename, str) or not filename:
    81	            continue
    82	        if not isinstance(summary, dict):
    83	            continue
    84	
    85	        lines = summary.get("lines", {})
    86	        functions = summary.get("functions", {})
    87	        regions = summary.get("regions", {})
    88	        if not isinstance(lines, dict):
