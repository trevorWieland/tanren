    45	def normalize_path(path_str: str, repo_root: Path) -> str:
    46	    """Normalize paths to repo-relative POSIX format where possible."""
    47	    candidate = Path(path_str)
    48	    if candidate.is_absolute():
    49	        try:
    50	            return candidate.relative_to(repo_root).as_posix()
    51	        except ValueError:
    52	            return candidate.as_posix()
