]

WRAPPER_REQUIRED = [
    'RUSTFLAGS="-D warnings" "${CARGO}" build -p tanren-mcp --locked --quiet',
    'candidate="${PWD}/${target_dir}/debug/tanren-mcp"',
    'export TANREN_MCP_BIN="${candidate}"',
    (
        '"${CARGO}" nextest run \\\n'
        "            -j1 \\\n"
        "            -p tanren-store \\\n"
