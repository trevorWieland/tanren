            --actor-public-key-file "${dir}/actor-public-key.pem" \
            --token-issuer "${issuer}" \
            --token-audience "${audience}" \
            --actor-token-max-ttl-secs 900 \
            > "${dir}/runs/${mode}-list.stdout.log" \
            2> "${dir}/runs/${mode}-list.stderr.log"
        echo "$?" > "${dir}/runs/${mode}-list.exit_code"
        set -e
    done

