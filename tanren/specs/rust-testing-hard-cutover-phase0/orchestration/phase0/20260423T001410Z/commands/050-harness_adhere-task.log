   428	# Enforce max file line count (500 lines per .rs file)
   429	check-lines:
   430	    #!/usr/bin/env bash
   431	    set -euo pipefail
   432	    echo "Checking .rs files for line count > {{ max_lines }}..."
   433	    failed=0
   434	    while IFS= read -r -d '' file; do
   435	        lines=$(wc -l < "$file")
   436	        if [[ "$lines" -gt {{ max_lines }} ]]; then
   437	            echo "FAIL: $file has $lines lines (max {{ max_lines }})"
   438	            failed=1
   439	        fi
   440	    done < <(find crates/ bin/ -name '*.rs' -print0)
   441	    if [[ "$failed" -eq 1 ]]; then exit 1; fi
   442	    echo "All files within line limit."
   443	
   444	# Enforce crate dependency layering (foundation crates must not depend on capability crates)
   445	check-deps:
   446	    #!/usr/bin/env bash
   447	    set -euo pipefail
   448	    echo "Checking crate dependency layering..."
   449	
   450	    # Foundation crates: domain logic, no I/O, no orchestration
   451	    foundation=(
   452	        "tanren-domain"
   453	        "tanren-contract"
   454	        "tanren-policy"
   455	        "tanren-observability"
   456	    )
   457	
   458	    # Capability crates: these must NOT be depended upon by foundation crates
   459	    capability=(
   460	        "tanren-store"
   461	        "tanren-planner"
   462	        "tanren-scheduler"
   463	        "tanren-orchestrator"
   464	        "tanren-app-services"
   465	        "tanren-runtime"
   466	        "tanren-runtime-local"
   467	        "tanren-runtime-docker"
   468	        "tanren-runtime-remote"
   469	        "tanren-harness-claude"
   470	        "tanren-harness-codex"
   471	        "tanren-harness-opencode"
   472	    )
   473	
   474	    failed=0
   475	    metadata=$({{ cargo }} metadata --format-version 1 --no-deps 2>/dev/null)
   476	
   477	    # Normal (non-dev, non-build) dependencies only. `cargo metadata`
   478	    # tags dev-dependencies with `kind="dev"` — those are test-only
   479	    # and never land in the shipped binary, so they do not constitute
   480	    # a layering violation.
   481	    for fnd in "${foundation[@]}"; do
   482	        deps=$(echo "$metadata" \
   483	            | jq -r ".packages[] | select(.name == \"$fnd\") | .dependencies[] | select(.kind == null) | .name" 2>/dev/null || true)
   484	        for cap in "${capability[@]}"; do
   485	            if echo "$deps" | grep -qx "$cap"; then
   486	                echo "FAIL: foundation crate '$fnd' depends on capability crate '$cap'"
   487	                failed=1
   488	            fi
   489	        done
   490	    done
   491	
   492	    # Transport binaries must stay thin: no direct core/capability deps.
   493	    transport=(
   494	        "tanren-cli"
   495	        "tanren-api"
   496	        "tanren-mcp"
   497	        "tanren-tui"
   498	    )
   499	    forbidden_transport=(
   500	        "tanren-domain"
   501	        "tanren-policy"
   502	        "tanren-store"
   503	        "tanren-planner"
   504	        "tanren-scheduler"
   505	        "tanren-orchestrator"
   506	    )
   507	    for bin in "${transport[@]}"; do
   508	        deps=$(echo "$metadata" \
   509	            | jq -r ".packages[] | select(.name == \"$bin\") | .dependencies[] | select(.kind == null) | .name" 2>/dev/null || true)
   510	        for forbidden in "${forbidden_transport[@]}"; do
   511	            if echo "$deps" | grep -qx "$forbidden"; then
   512	                echo "FAIL: transport binary '$bin' depends directly on '$forbidden'"
   513	                failed=1
   514	            fi
   515	        done
   516	    done
   517	
   518	    # Store row-shape entities must remain crate-internal.
   519	    if grep -Eq '^[[:space:]]*pub mod entity;' crates/tanren-store/src/lib.rs; then
   520	        echo "FAIL: crates/tanren-store/src/lib.rs exports 'pub mod entity;'"
   521	        failed=1
   522	    fi
   523	    if grep -Eq '^[[:space:]]*pub mod (dispatch_projection|events|step_projection);' crates/tanren-store/src/entity/mod.rs; then
   524	        echo "FAIL: crates/tanren-store/src/entity/mod.rs exposes row-shape modules publicly"
   525	        failed=1
   526	    fi
   527	    if ! awk '
   528	        prev_cfg && /^[[:space:]]*pub use state_store::dispatch_query_statement_for_backend;/ {ok=1}
   529	        { prev_cfg = ($0 ~ /^[[:space:]]*#\[cfg\(feature = "test-hooks"\)\][[:space:]]*$/) }
   530	        END { exit ok ? 0 : 1 }
   531	    ' crates/tanren-store/src/lib.rs; then
   532	        echo "FAIL: dispatch_query_statement_for_backend re-export must be gated by #[cfg(feature = \"test-hooks\")]"
   533	        failed=1
   534	    fi
   535	    if ! awk '
   536	        prev_cfg && /^[[:space:]]*pub fn dispatch_query_statement_for_backend\(/ {ok=1}
   537	        { prev_cfg = ($0 ~ /^[[:space:]]*#\[cfg\(feature = "test-hooks"\)\][[:space:]]*$/) }
   538	        END { exit ok ? 0 : 1 }
   539	    ' crates/tanren-store/src/state_store.rs; then
   540	        echo "FAIL: dispatch_query_statement_for_backend function must be gated by #[cfg(feature = \"test-hooks\")]"
   541	        failed=1
   542	    fi
   543	
   544	    if [[ "$failed" -eq 1 ]]; then
   545	        echo "Dependency/boundary rule violations detected."
   546	        exit 1
   547	    fi
   548	    echo "Crate layering rules pass."
