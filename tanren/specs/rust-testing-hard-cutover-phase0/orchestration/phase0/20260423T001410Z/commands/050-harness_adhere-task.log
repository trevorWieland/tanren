   152	    world.persisted_revision += 1;
   153	    world.last_mutation_error = None;
   154	    Ok(())
   155	}
   156	
   157	fn parse_replay_event(event: &str) -> Option<String> {
   158	    let status = event.strip_prefix("status:")?;
   159	    if matches!(status, "planned" | "active" | "completed" | "cancelled") {
   160	        return Some(event.to_string());
   161	    }
   162	    None
   163	}
   164	
   165	fn replay_history(world: &mut Phase0World) {
   166	    let mut scratch = Vec::new();
   167	
   168	    for (index, event) in world.replay_source_history.iter().enumerate() {
   169	        let Some(parsed_event) = parse_replay_event(event) else {
   170	            world.replay_error = Some(format!("invalid_event_at_index:{index}"));
   171	            world.replayed_snapshot.clear();
   172	            world.replay_applied_count = 0;
   173	            return;
   174	        };
   175	        scratch.push(parsed_event);
   176	    }
   177	
   178	    world.replay_error = None;
   179	    world.replayed_snapshot = scratch;
   180	    world.replay_applied_count = world.replayed_snapshot.len();
   181	}
   182	
   183	fn auth_error_label(error: AuthErrorCode) -> &'static str {
   184	    match error {
   185	        AuthErrorCode::InvalidIdentity => "invalid_identity",
   186	        AuthErrorCode::ReplayCredential => "replay_credential",
   187	    }
   188	}
   189	
   190	fn authorize(world: &Phase0World, replay_credential_used: bool) -> Result<(), AuthErrorCode> {
   191	    if !world.actor_identity_valid {
   192	        return Err(AuthErrorCode::InvalidIdentity);
   193	    }
   194	    if replay_credential_used || !world.replay_credential_fresh {
   195	        return Err(AuthErrorCode::ReplayCredential);
   196	    }
   197	    Ok(())
   198	}
   199	
   200	fn execute_protected_command(
   201	    world: &mut Phase0World,
   202	    command: &str,
   203	    replay_credential_used: bool,
   204	) -> Result<(), AuthErrorCode> {
   205	    authorize(world, replay_credential_used)?;
   206	
   207	    match command {
   208	        "create" => {
   209	            if world.lifecycle_state == LifecycleState::New {
   210	                world.lifecycle_state = LifecycleState::Active;
   211	                world.protected_mutation_count += 1;
   212	                world.command_outcomes.push("create:accepted".to_string());
   213	            } else {
   214	                world
   215	                    .command_outcomes
   216	                    .push("create:rejected:invalid_transition".to_string());
   217	            }
   218	        }
   219	        "inspect" => world.command_outcomes.push("inspect:accepted".to_string()),
   220	        "list" => world.command_outcomes.push("list:accepted".to_string()),
   221	        "cancel" => {
   222	            if world.lifecycle_state == LifecycleState::Active {
   223	                world.lifecycle_state = LifecycleState::Cancelled;
   224	                world.protected_mutation_count += 1;
   225	                world.command_outcomes.push("cancel:accepted".to_string());
   226	            } else {
   227	                world
   228	                    .command_outcomes
   229	                    .push("cancel:rejected:invalid_transition".to_string());
   230	            }
   231	        }
   232	        _ => world
   233	            .command_outcomes
   234	            .push("unknown:rejected:unsupported_command".to_string()),
   235	    }
   236	
   237	    Ok(())
   238	}
