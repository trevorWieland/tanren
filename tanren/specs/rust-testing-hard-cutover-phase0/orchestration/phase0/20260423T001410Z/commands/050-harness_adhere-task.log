   550	# Verify local CI recipes stay aligned with workflow strict rust commands.
   551	check-ci-parity:
   552	    #!/usr/bin/env bash
   553	    set -euo pipefail
   554	
   555	    uv_bin="$(command -v uv || true)"
   556	    if [[ -z "$uv_bin" && -x "$HOME/.local/bin/uv" ]]; then
   557	        uv_bin="$HOME/.local/bin/uv"
   558	    fi
   559	    if [[ -z "$uv_bin" ]]; then
   560	        echo "FAIL: uv not found. Install uv or add it to PATH."
   561	        exit 127
   562	    fi
   563	
   564	    # Keep cache local when HOME cache is unavailable (sandboxed runs).
   565	    export UV_CACHE_DIR="${UV_CACHE_DIR:-$PWD/.uv-cache}"
   566	    "$uv_bin" run python scripts/check_ci_parity.py
   567	
   568	# Verify active rustc/clippy match the pinned toolchain in rust-toolchain.toml.
   569	check-rust-toolchain-sync:
   570	    #!/usr/bin/env bash
   571	    set -euo pipefail
   572	
   573	    expected="$(awk -F'"' '/^channel[[:space:]]*=/{print $2; exit}' rust-toolchain.toml)"
   574	    if [[ -z "${expected:-}" ]]; then
   575	        echo "FAIL: rust-toolchain.toml missing pinned channel."
   576	        exit 1
   577	    fi
   578	
   579	    rustc_version="$(rustc -V | awk '{print $2}')"
   580	    if [[ "$rustc_version" != "$expected" ]]; then
   581	        echo "FAIL: active rustc is ${rustc_version}, expected ${expected} from rust-toolchain.toml."
   582	        exit 1
   583	    fi
   584	
   585	    rustc_hash="$(rustc -Vv | awk '$1 == "commit-hash:" {print $2}')"
   586	    clippy_hash="$(
   587	        cargo clippy --version \
   588	            | awk -F'[()]' '{print $2}' \
   589	            | awk '{print $1}' \
   590	            | awk '/^[0-9a-f]+$/ {print; exit}'
   591	    )"
   592	    if [[ -z "${rustc_hash:-}" || -z "${clippy_hash:-}" ]]; then
   593	        echo "FAIL: unable to parse rustc/clippy version metadata."
   594	        exit 1
   595	    fi
   596	
   597	    rustc_short="${rustc_hash:0:10}"
   598	    if [[ "$clippy_hash" != "$rustc_short" ]]; then
   599	        echo "FAIL: clippy commit ${clippy_hash} does not match rustc commit ${rustc_short}."
   600	        exit 1
   601	    fi
   602	    echo "Rust toolchain sync check passed (${expected}, ${rustc_short})."
   603	
   604	# Prohibit inline lint suppression (#[allow/expect])
   605	check-suppression:
   606	    #!/usr/bin/env bash
   607	    set -euo pipefail
   608	    echo "Checking for inline lint suppression..."
   609	    found=0
   610	    if grep -rn '#\[allow(' crates/ bin/ --include='*.rs' 2>/dev/null; then
   611	        echo "FAIL: Found #[allow(...)] in source. Move to [lints] in Cargo.toml."
   612	        found=1
   613	    fi
   614	    if grep -rn '#\[expect(' crates/ bin/ --include='*.rs' 2>/dev/null; then
   615	        echo "FAIL: Found #[expect(...)] in source. Move to [lints] in Cargo.toml."
   616	        found=1
   617	    fi
   618	    if grep -rn '#!\[allow(' crates/ bin/ --include='*.rs' 2>/dev/null; then
   619	        echo "FAIL: Found #![allow(...)] in source. Move to [lints] in Cargo.toml."
   620	        found=1
   621	    fi
   622	    if [[ "$found" -eq 1 ]]; then exit 1; fi
   623	    echo "No inline lint suppression found."
