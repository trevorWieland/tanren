   142	    next: LifecycleState,
   143	) -> Result<(), MutationErrorCode> {
   144	    if !transition_allowed(world.lifecycle_state, next) {
   145	        world.last_mutation_error = Some(MutationErrorCode::InvalidTransition);
   146	        return Err(MutationErrorCode::InvalidTransition);
   147	    }
