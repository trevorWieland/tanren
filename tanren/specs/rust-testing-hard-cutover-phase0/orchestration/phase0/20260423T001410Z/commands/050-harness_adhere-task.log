   291	# Phase 0 staged scenario gate scaffold (non-blocking until final enforcement).
   292	check-phase0-scenario-stage:
   293	    #!/usr/bin/env bash
   294	    set -euo pipefail
   295	
   296	    bdd_source="docs/rewrite/PHASE0_PROOF_BDD.md"
   297	    scenario_count=0
   298	    if [[ -f "$bdd_source" ]]; then
   299	        scenario_count="$(grep -Ec '^### Scenario [0-9]+\.[0-9]+:' "$bdd_source" || true)"
   300	        echo "Phase 0 scenario scaffold: found ${scenario_count} scenario headings in ${bdd_source}."
   301	    else
   302	        echo "Phase 0 scenario scaffold: ${bdd_source} not found (non-blocking in scaffold mode)."
   303	    fi
   304	
   305	    feature_count=0
   306	    if [[ -d tests/bdd/phase0 ]]; then
   307	        feature_count="$(find tests/bdd/phase0 -type f -name '*.feature' | wc -l | tr -d '[:space:]')"
   308	    fi
   309	    echo "Phase 0 scenario scaffold: detected ${feature_count} feature file(s) under tests/bdd/phase0."
   310	
   311	# Run a cucumber-rs smoke scenario for the Phase 0 BDD harness scaffold.
   312	check-phase0-bdd-smoke:
   313	    #!/usr/bin/env bash
   314	    set -euo pipefail
   315	
   316	    feature_file="tests/bdd/phase0/smoke.feature"
   317	    if [[ ! -f "$feature_file" ]]; then
   318	        echo "FAIL: missing Phase 0 smoke feature at ${feature_file}."
   319	        exit 1
   320	    fi
   321	
   322	    {{ cargo }} run --quiet -p tanren-bdd-phase0 --locked
   323	
   324	    tag_line="$(grep -E '^@' "$feature_file" | head -n 1 || true)"
   325	    if [[ -z "$tag_line" ]]; then
   326	        echo "FAIL: no tag line found in ${feature_file}."
   327	        exit 1
   328	    fi
   329	    echo "Phase 0 BDD smoke tag evidence: ${tag_line}"
   330	
   331	# Run Wave A cucumber-rs scenarios (Features 1-3) for Phase 0.
   332	check-phase0-bdd-wave-a:
   333	    #!/usr/bin/env bash
   334	    set -euo pipefail
   335	
   336	    feature_files=(
   337	        "tests/bdd/phase0/feature-1-typed-control-plane-state.feature"
   338	        "tests/bdd/phase0/feature-2-event-history.feature"
   339	        "tests/bdd/phase0/feature-3-contract-derived-interface.feature"
   340	    )
   341	
   342	    for feature_file in "${feature_files[@]}"; do
   343	        if [[ ! -f "$feature_file" ]]; then
   344	            echo "FAIL: missing Phase 0 Wave A feature at ${feature_file}."
   345	            exit 1
   346	        fi
   347	        TANREN_BDD_PHASE0_FEATURE_PATH="$feature_file" \
   348	            {{ cargo }} run --quiet -p tanren-bdd-phase0 --locked
   349	
   350	        tag_line="$(grep -E '^[[:space:]]*@.*@BEH-P0-(101|102|201|202|203|301|302)' "$feature_file" | head -n 1 || true)"
   351	        if [[ -z "$tag_line" ]]; then
   352	            echo "FAIL: no Wave A behavior tag line found in ${feature_file}."
   353	            exit 1
   354	        fi
   355	        echo "Phase 0 Wave A BDD tag evidence (${feature_file}): ${tag_line}"
   356	    done
