use cucumber::{given, then, when};

use crate::Phase0World;

fn evaluate_guard_completion(world: &mut Phase0World) {
    world.completion_emitted = world
        .required_guards
        .iter()
        .all(|guard| world.satisfied_guards.contains(guard));
}

