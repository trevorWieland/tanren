      --args \""'$score" > /tmp/tanren_audit_t12_rubric_payload.json
  else
    jq -n '"\\
      --arg spec_id \""'$spec_id" '"\\
      --arg task_id \""'$task_id" '"\\
      --arg pillar \""'$pillar" '"\\
      --arg rationale \""'$rationale" '"\\
      '{schema_version:\"1.0.0\",spec_id:"'$spec_id,scope:"task",scope_target_id:$task_id,pillar:$pillar,score:($ARGS.positional[0]|tonumber),target:10,passing:7,rationale:$rationale}'"' \\
      --args \""'$score" > /tmp/tanren_audit_t12_rubric_payload.json
  fi

  tanren-cli --database-url "sqlite:tanren.db?mode=rwc" methodology --phase "audit-task" --spec-id "$spec_id" --spec-folder "tanren/specs/rust-testing-hard-cutover-phase0" rubric record --params-file /tmp/tanren_audit_t12_rubric_payload.json >/tmp/tanren_audit_t12_rubric_${pillar}.json
