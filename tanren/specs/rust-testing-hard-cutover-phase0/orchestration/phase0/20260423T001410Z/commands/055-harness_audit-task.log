    #!/usr/bin/env bash
    set -euo pipefail

    feature_files=(
        "tests/bdd/phase0/feature-4-methodology-boundary.feature"
        "tests/bdd/phase0/feature-5-task-completion-guards.feature"
        "tests/bdd/phase0/feature-6-tool-surface-contract.feature"
