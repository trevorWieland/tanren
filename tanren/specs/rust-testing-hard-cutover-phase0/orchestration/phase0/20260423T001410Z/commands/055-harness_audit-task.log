    for feature_file in "${feature_files[@]}"; do
        if [[ ! -f "$feature_file" ]]; then
            echo "FAIL: missing Phase 0 Wave B feature at ${feature_file}."
            exit 1
        fi
        TANREN_BDD_PHASE0_FEATURE_PATH="$feature_file" \
