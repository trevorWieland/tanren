        tag_line="$(grep -E '^[[:space:]]*@.*@BEH-P0-(401|402|501|502|601|602|603)' "$feature_file" | head -n 1 || true)"
        if [[ -z "$tag_line" ]]; then
            echo "FAIL: no Wave B behavior tag line found in ${feature_file}."
