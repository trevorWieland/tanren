+        echo "FAIL: expected at least 9 feature files under tests/bdd/phase0; found ${feature_count}."
+        exit 1
+    fi
+    echo "Phase 0 strict scenario gate: detected ${feature_count} feature file(s) under tests/bdd/phase0."
