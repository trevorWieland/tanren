set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
cd "${REPO_ROOT}"

ENFORCE_STRICT="${PHASE0_COVERAGE_ENFORCE:-0}"
if [[ "${ENFORCE_STRICT}" == "1" || "${ENFORCE_STRICT}" == "true" ]]; then
