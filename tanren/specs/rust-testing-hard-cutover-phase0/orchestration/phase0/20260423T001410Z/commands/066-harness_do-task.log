OUTPUT_ROOT="${PHASE0_COVERAGE_OUTPUT_ROOT:-${DEFAULT_OUTPUT_ROOT}}"
TRACEABILITY_PATH="${PHASE0_BEHAVIOR_TRACEABILITY_FILE:-${REPO_ROOT}/docs/rewrite/PHASE0_BEHAVIOR_TRACEABILITY.json}"

