REPO_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
cd "${REPO_ROOT}"

ENFORCE_STRICT="${PHASE0_MUTATION_ENFORCE:-0}"
if [[ "${ENFORCE_STRICT}" == "1" || "${ENFORCE_STRICT}" == "true" ]]; then
