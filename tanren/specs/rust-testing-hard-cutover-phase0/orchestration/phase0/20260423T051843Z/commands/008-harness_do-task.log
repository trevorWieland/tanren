/bin/zsh -lc "uv run python - <<'PY'
import json
from collections import Counter, defaultdict
from datetime import datetime

path = 'tanren/specs/rust-testing-hard-cutover-phase0/phase-events.jsonl'

phase_outcomes = []
task_started = []
task_completed = []

with open(path, 'r', encoding='utf-8') as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        evt = json.loads(line)
        payload = evt.get('payload', {})
        et = payload.get('event_type')
        ts = evt.get('timestamp')
        phase = evt.get('phase')
        if et == 'phase_outcome_reported':
            out = payload.get('outcome', {})
            phase_outcomes.append((phase, out.get('outcome'), out.get('summary', ''), ts))
        elif et == 'task_started':
            task_started.append((payload.get('task_id'), ts))
        elif et == 'task_completed':
            task_completed.append((payload.get('task_id'), ts))

cnt = Counter((p, o) for p, o, _, _ in phase_outcomes)

blocked = [(p,s,t) for p,o,s,t in phase_outcomes if o == 'blocked']
investigations = [(s,t) for p,o,s,t in phase_outcomes if p == 'investigate' and o == 'complete']

print('PHASE_OUTCOME_COUNTS')
for (p,o), n in sorted(cnt.items()):
    print(f'{p}|{o}|{n}')

print('\\nBLOCKED_OUTCOMES')
for p,s,t in blocked:
    print(f'{t}|{p}|{s}')

print('\\nINVESTIGATE_COMPLETIONS')
for s,t in investigations:
    print(f'{t}|{s}')

print('\\nTASK_COUNTS')
print(f'task_started={len(task_started)}')
print(f'task_completed={len(task_completed)}')

if task_started:
    first = min(datetime.fromisoformat(ts.replace('Z', '+00:00')) for _, ts in task_started)
    last = max(datetime.fromisoformat(ts.replace('Z', '+00:00')) for _, ts in task_started)
    print(f'first_task_start={first.isoformat()}')
    print(f'last_task_start={last.isoformat()}')
