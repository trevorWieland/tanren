   241	/// The 13 built-in pillars per `docs/architecture/audit-rubric.md` §3.
   242	#[must_use]
   243	pub fn builtin_pillars() -> Vec<Pillar> {
   244	    let target = PillarScore::try_new(10).expect("built-in target is 10");
   245	    let passing = PillarScore::try_new(7).expect("built-in passing is 7");
   246	    BUILTIN_ROWS
   247	        .iter()
   248	        .map(|(id, name, td, sd, app)| Pillar {
   249	            id: PillarId::try_new(*id).expect("static id is non-empty"),
   250	            name: NonEmptyString::try_new(*name).expect("static name is non-empty"),
   251	            task_description: NonEmptyString::try_new(*td).expect("static desc is non-empty"),
   252	            spec_description: NonEmptyString::try_new(*sd).expect("static desc is non-empty"),
   253	            target_score: target,
   254	            passing_score: passing,
   255	            applicable_at: *app,
   256	        })
   257	        .collect()
   258	}
