# Audit rubric — 13 built-in pillars per
# `docs/architecture/audit-rubric.md` §3.
#
# Each pillar scores 1..=10, passing at ≥7, target 10. The methodology
# service enforces the linkage invariants at record-time (Lane 0.5
# Wave 8): `score < target` requires supporting findings; `score <
# passing` requires at least one `fix_now` supporting finding.
#
# This file is authoritative for the tanren repo. Adopters copy it
# via `tanren install`; they may then override, remove, or extend
# pillars locally. A pillar's `applicable_at` filter restricts it
# to task-scope, spec-scope, or both.

pillars:
  - id: completeness
    name: Completeness
    task_description: Acceptance criteria fully met; no silent deferrals.
    spec_description: Spec's acceptance criteria fully met across all implementing tasks.
    target_score: 10
    passing_score: 7
    applicable_at: both

  - id: performance
    name: Performance
    task_description: No gratuitous inefficiency; benchmarks where SLAs apply.
    spec_description: Spec-level latency, memory, and throughput budgets honored.
    target_score: 10
    passing_score: 7
    applicable_at: both

  - id: scalability
    name: Scalability
    task_description: Scales from N=1 to large N; no hard-coded constants breaking at scale.
    spec_description: End-to-end flows scale under target load profiles.
    target_score: 10
    passing_score: 7
    applicable_at: both

  - id: strictness
    name: Strictness
    task_description: Invariants encoded in types; no stringly-typed state; no unwrap/panic in library code.
    spec_description: Cross-cutting invariants compile-time-enforced across the spec surface.
    target_score: 10
    passing_score: 7
    applicable_at: both

  - id: security
    name: Security
    task_description: No secrets in logs; inputs validated at boundaries; authz enforced; secrets wrapped.
    spec_description: Spec-level threat model addressed; no new unreviewed attack surface.
    target_score: 10
    passing_score: 7
    applicable_at: both

  - id: stability
    name: Stability
    task_description: No panics; tests deterministic; races absent; retries/backoff correct.
    spec_description: Integration tests deterministic; no flaky interactions across tasks.
    target_score: 10
    passing_score: 7
    applicable_at: both

  - id: maintainability
    name: Maintainability
    task_description: Module boundaries sensible; names precise; dead code absent.
    spec_description: Spec-level architecture legible; boundaries and ownership clear.
    target_score: 10
    passing_score: 7
    applicable_at: both

  - id: extensibility
    name: Extensibility
    task_description: Pluggable where variation likely; no premature abstraction.
    spec_description: Spec leaves clean extension seams for anticipated follow-up work.
    target_score: 10
    passing_score: 7
    applicable_at: both

  - id: elegance
    name: Elegance
    task_description: Simplest solution solving the real problem; no boilerplate-for-boilerplate.
    spec_description: Overall spec design is the simplest thing that meets the non-negotiables.
    target_score: 10
    passing_score: 7
    applicable_at: both

  - id: style
    name: Style
    task_description: Matches existing code; 2026 best practices; no legacy patterns kept for themselves.
    spec_description: Spec-wide style is internally consistent and idiomatic to the project.
    target_score: 10
    passing_score: 7
    applicable_at: both

  - id: relevance
    name: Relevance
    task_description: All changes related to the task; no unrelated drive-by edits.
    spec_description: Spec-level changes are scoped to the stated acceptance criteria.
    target_score: 10
    passing_score: 7
    applicable_at: both

  - id: modularity
    name: Modularity
    task_description: Boundaries honor the dependency DAG; no cross-cutting leaks.
    spec_description: Spec-level crate/module graph respects architectural layering.
    target_score: 10
    passing_score: 7
    applicable_at: both

  - id: documentation_complete
    name: Documentation Complete
    task_description: Doc comments updated; stale docs pruned; new public APIs documented.
    spec_description: Spec-level documentation matches the shipped behavior.
    target_score: 10
    passing_score: 7
    applicable_at: both

