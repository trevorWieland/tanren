# tanren Daemon configuration
# All core variables use the WM_ prefix.
# Copy to daemon.env and edit before running docker compose.
# Paths below are container-internal; mount host directories via volumes.
#
# See docs/secrets.md for the full secret taxonomy and deployment guide.

# ═══════════════════════════════════════════════════════════════════════════
# OPERATIONAL CONFIG — tanren daemon settings
# ═══════════════════════════════════════════════════════════════════════════

# ── Filesystem paths (required) ──────────────────────────────────────────
WM_IPC_DIR=/data/ipc
WM_GITHUB_DIR=/repos
WM_DATA_DIR=/data/daemon
WM_COMMANDS_DIR=.claude/commands/tanren
WM_WORKTREE_REGISTRY_PATH=/data/daemon/worktrees.json
WM_ROLES_CONFIG_PATH=/config/roles.yml

# ── CLI binary paths (required) ──────────────────────────────────────────
# These CLIs must be available inside the container.
# Mount from host via docker-compose volumes, or set to a noop
# if using remote-only execution (CLIs run on the remote VM).
WM_OPENCODE_PATH=opencode
WM_CODEX_PATH=codex
WM_CLAUDE_PATH=claude

# ── Polling and concurrency (required) ───────────────────────────────────
WM_POLL_INTERVAL=5
WM_HEARTBEAT_INTERVAL=30
WM_MAX_OPENCODE=1
WM_MAX_CODEX=1
WM_MAX_GATE=3

# ── Database (must match TANREN_API_DB_URL) ──────────────────────────────
WM_EVENTS_DB=/data/tanren.db
# Postgres: WM_EVENTS_DB=postgresql://tanren:changeme@postgres:5432/tanren

# ── Remote execution (optional) ──────────────────────────────────────────
# WM_REMOTE_CONFIG=/config/remote.yml

# ── Token usage collection (optional) ────────────────────────────────────
# WM_CCUSAGE_CLAUDE_CMD=npx ccusage
# WM_CCUSAGE_CODEX_CMD=npx @ccusage/codex
# WM_CCUSAGE_OPENCODE_CMD=npx @ccusage/opencode

# ═══════════════════════════════════════════════════════════════════════════
# INFRASTRUCTURE SECRETS — used by the daemon, never sent to VMs
# ═══════════════════════════════════════════════════════════════════════════

# ── Hetzner adapter ──────────────────────────────────────────────────────
# Required when remote.yml provisioner.type = "hetzner"
# HCLOUD_TOKEN=

# ── GCP adapter ──────────────────────────────────────────────────────────
# Required when remote.yml provisioner.type = "gcp"
# GCP_SSH_PUBLIC_KEY=ssh-ed25519 AAAA...
# GOOGLE_APPLICATION_CREDENTIALS=/config/service-account.json

# ── Git authentication ───────────────────────────────────────────────────
# Used by GIT_ASKPASS on VMs for git clone/push (resolved via git.token_env
# in remote.yml). Never appears in CLI process args.
# GIT_TOKEN=

# ── Issue trackers (optional) ────────────────────────────────────────────
# GITHUB_TOKEN=
# LINEAR_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# DEVELOPER SECRETS — injected onto VMs for CLI authentication
# Dispatches carry secret *names* in required_secrets; the daemon resolves
# the values from these env vars at provision time. Secret values never
# appear in the dispatch payload or the database.
#
# Single-developer: put your credentials here.
# Team: use a secret manager instead (see docs/secrets.md).
# ═══════════════════════════════════════════════════════════════════════════

# ── Claude Code ──────────────────────────────────────────────────────────
# CLAUDE_CODE_OAUTH_TOKEN=          # Preferred: OAuth token
# CLAUDE_CREDENTIALS_JSON=          # Alternative: full credentials JSON blob

# ── Opencode ─────────────────────────────────────────────────────────────
# OPENCODE_ZAI_API_KEY=             # Z.ai API key

# ── Codex ────────────────────────────────────────────────────────────────
# CODEX_AUTH_JSON=                   # ChatGPT Plus auth JSON blob

# ── MCP servers ──────────────────────────────────────────────────────────
# ARKAIVE_MCP_KEY=                   # MCP server credentials (name must match
# MCP_CONTEXT7_KEY=                  # $VAR refs in tanren.yml mcp headers)
