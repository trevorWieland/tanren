# tanren API configuration
# All variables use the TANREN_API_ prefix.
# Copy to api.env and edit before running docker compose.

# Required ─────────────────────────────────────────────────────────────────────
TANREN_API_API_KEY=changeme
TANREN_API_DB_URL=/data/tanren.db

# Optional (defaults shown) ────────────────────────────────────────────────────
# TANREN_API_HOST=0.0.0.0
# TANREN_API_PORT=8000
# TANREN_API_LOG_LEVEL=info
# TANREN_API_WORKERS=1
# TANREN_API_CORS_ORIGINS=["http://localhost:3000"]

# Postgres (uncomment and set when using --profile postgres) ───────────────────
# TANREN_API_DB_URL=postgresql://tanren:changeme@postgres:5432/tanren
