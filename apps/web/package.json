{
  "name": "@tanren/web",
  "version": "0.0.0",
  "private": true,
  "description": "Tanren responsive web UI. F-0001 ships a placeholder route that fetches the API's /health endpoint and renders the response.",
  "scripts": {
    "dev": "concurrently -n paraglide,vite \"paraglide-js compile --project ./src/i18n/project.inlang --outdir ./src/i18n/paraglide --emit-ts-declarations --watch\" \"vite --host 127.0.0.1 --port ${PLAYWRIGHT_WEB_PORT:-3000}\"",
    "build": "paraglide-js compile --project ./src/i18n/project.inlang --outdir ./src/i18n/paraglide --emit-ts-declarations && vite build",
    "start": "vite preview",
    "i18n:compile": "paraglide-js compile --project ./src/i18n/project.inlang --outdir ./src/i18n/paraglide --emit-ts-declarations",
    "lint": "oxlint .",
    "typecheck": "tsgo --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --project=unit --passWithNoTests",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:test": "vitest run --project=storybook",
    "bddgen": "bddgen",
    "e2e": "bddgen && playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "generate-api": "node scripts/generate-api-client.mjs"
  },
  "dependencies": {
    "@inlang/paraglide-js": "catalog:default",
    "next": "catalog:default",
    "react": "catalog:default",
    "react-dom": "catalog:default",
    "tailwindcss": "catalog:default",
    "@tanstack/react-query": "catalog:default",
    "valibot": "catalog:default"
  },
  "devDependencies": {
    "@axe-core/playwright": "catalog:default",
    "@playwright/test": "catalog:default",
    "@storybook/addon-a11y": "catalog:default",
    "@storybook/addon-vitest": "catalog:default",
    "@storybook/nextjs-vite": "catalog:default",
    "@tailwindcss/postcss": "catalog:default",
    "@types/node": "catalog:default",
    "@types/react": "catalog:default",
    "@types/react-dom": "catalog:default",
    "@typescript/native-preview": "catalog:default",
    "@vitejs/plugin-react": "catalog:default",
    "@vitest/browser": "catalog:default",
    "@vitest/browser-playwright": "catalog:default",
    "concurrently": "catalog:default",
    "openapi-typescript": "^7.13.0",
    "oxlint": "catalog:default",
    "playwright-bdd": "catalog:default",
    "prettier": "catalog:default",
    "storybook": "catalog:default",
    "typescript": "catalog:default",
    "vite": "catalog:default",
    "vitest": "catalog:default"
  }
}
